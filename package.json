{
  "name": "organic-chemistry-tutor-ib-db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "server": "node server/index.mjs",
    "client": "npm run dev --prefix client",
    "dev": "concurrently -k \"npm run server\" \"npm run client\"",
    "start": "npm run dev",
    "build": "npm run build --prefix client",
    "lint": "npm run lint --prefix client",
    "migrate": "node server/migrate.mjs",
    "import": "node server/import-youtube.mjs --handle @TheOrganicChemistryTutor",
    "import:limit": "node server/import-youtube.mjs --handle @TheOrganicChemistryTutor --limit 50",
    "durations": "node server/backfill-durations.mjs"
  },
  "dependencies": {
    "express": "^4.19.2",
    "cors": "^2.8.5",
    "concurrently": "^8.2.2"
  }
}
